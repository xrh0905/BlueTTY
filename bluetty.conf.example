[bluez]
ProfilePath=/com/bluetty/spp_profile
Uuid=00001101-0000-1000-8000-00805f9b34fb
Name=SPP Getty
RequireAuthentication=false
RequireAuthorization=false

[session]
Mode=getty
SubcommandTemplate=/sbin/agetty -8 -s -L --noclear -H {host} --login-program /bin/login {tty} xterm-256color
HupFallback=false
MaxSessions=0
